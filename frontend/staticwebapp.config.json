{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/static/*", "/*.{css,js,ico,png,svg,json,txt,map}"]
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html",
      "statusCode": 200
    }
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "Referrer-Policy": "no-referrer"
  },
  "mimeTypes": {
    ".json": "application/json"
  }
}
